      "steps": ["dev/planner", "dev/coder", "dev/reviewer", "ops/security", "ops/verificador", "ops/orquestador-swarm"],
      "required_states_by_step": {
        "dev/planner": ["S-HISTORIA"],
        "dev/coder": ["S-PLANIFICAR", "S-INTEGRAR"],
        "dev/reviewer": ["S-REVIEW", "S-VEREDICTO"],
        "ops/security": ["S-ANALISIS-PR"],
        "ops/verificador": ["S-VERIFICAR", "S-CAPA-SEGURIDAD"],
        "ops/orquestador-swarm": ["S-GOLDEN-PATH"]
