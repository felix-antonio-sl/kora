      "required_tools_by_step": {
        "dev/planner": ["story_refine"],
        "dev/coder": ["implementation_plan", "pr_generate"],
        "dev/reviewer": ["pr_read", "verdict_issue"],
        "ops/security": ["pr_security_analyze"],
        "ops/verificador": ["security_scan", "verification_report"],
        "ops/orquestador-swarm": ["golden_path_execute", "agent_dispatch"]
      },
      "required_routes": [["dev/planner", "dev/coder"], ["dev/coder", "dev/reviewer"]]
