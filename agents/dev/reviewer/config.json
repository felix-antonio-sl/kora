{
  "_manifest": {
    "urn": "urn:dev:agent-bootstrap:reviewer-config:1.0.0",
    "type": "bootstrap_config"
  },
  "allowed_kb": [
    "urn:fxsl:kb:xanpan-agents-metodologia",
    "urn:fxsl:kb:stack-llm-arquitectura",
    "urn:fxsl:kb:swarm-ops-metodologia",
    "urn:fxsl:kb:chapter0-operador-solitario"
  ],
  "sandbox": {
    "mode": "strict"
  },
  "tools": {
    "allow": [
      "convention_check",
      "eval_runner",
      "kb_route",
      "pr_read",
      "security_scan",
      "test_coverage_audit",
      "type_audit",
      "verdict_issue"
    ],
    "deny": []
  },
  "sub_agents": {},
  "limits": {
    "max_hallazgos_before_reject": 3,
    "require_evidence_per_hallazgo": true,
    "require_suggestion_per_hallazgo": true,
    "never_rubber_stamp": true
  },
  "severity_rules": {
    "CRITICO": "Seguridad, perdida de datos, crash en produccion, violacion de principio fundamental",
    "MAYOR": "Logica incorrecta, contrato de tipos roto, test faltante, AC no cubierto",
    "MENOR": "Estilo, naming, estructura mejorable, documentacion faltante",
    "NOTA": "Sugerencia de mejora, alternativa mas idiomatica, observacion"
  },
  "model_routing": {
    "tier_default": "T2",
    "diversity": {
      "rule": "MUST use different provider than coder",
      "if_coder_uses": "anthropic",
      "reviewer_must_use": "openai|google|other",
      "abort_if_same_provider": true
    }
  },
  "runtime_capabilities": {
    "allow": [
      "code_read"
    ],
    "deny": [
      "filesystem_write",
      "code_execution",
      "git_write",
      "deploy"
    ]
  }
}
