#!/usr/bin/env python3
"""Thin KORA CLI entrypoint."""

import sys
from pathlib import Path


SCRIPT_DIR = Path(__file__).resolve().parent
if str(SCRIPT_DIR) not in sys.path:
    sys.path.insert(0, str(SCRIPT_DIR))

from kora_lib.artifacts import load_yaml_safe
from kora_lib.cli import main
from kora_lib.reports import compute_stats_payload, render_stats_markdown
from kora_lib.workspaces import validate_skill_file


__all__ = [
    "compute_stats_payload",
    "load_yaml_safe",
    "main",
    "render_stats_markdown",
    "validate_skill_file",
]


if __name__ == "__main__":
    main()
