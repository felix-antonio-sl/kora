@prefix gnub: <https://gorenuble.gob.cl/ns/ontology/> .
@prefix gnubd: <https://gorenuble.gob.cl/ns/data/> .
@prefix gist: <https://w3id.org/semanticarts/ns/ontology/gist/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# DATOS ORGANIZACIONALES GORE ÑUBLE (ABox)
# Fuente: staging/organigrama_gore_2026.md (estructura efectiva 2026-01-16),
#         knowledge/domains/gn/01_fundamentos/intro/kb_gn_002_organigrama_koda.yml,
#         omega_gore_nuble_mermaid.md (modelo omega actualizado)
# =============================================================================
# CONVENCIÓN DE URIs (C4 - Documentación):
#   - Este archivo usa prefijo "_" + PascalCase: _Org_GORE_Nuble, _Div_DIPLADE
#   - Archivos nuevos (ApprovalData, RenditionData) usan MixedCase sin prefijo
#   - Ambas convenciones son válidas; mantener consistencia dentro de cada archivo
# ORDEN DE CARGA (M2):
#   1. goreNubleOntology.ttl (TBox)
#   2. goreNubleOrgData.ttl (este archivo - define UoM y Aspects compartidos)
#   3. goreNubleIPRData.ttl, goreNubleLegalData.ttl (dependen de OrgData)
#   4. goreNubleApprovalData.ttl, goreNubleRenditionData.ttl (independientes)
# =============================================================================

<https://gorenuble.gob.cl/data/goreNubleOrgData>
    a owl:Ontology ;
    owl:imports <https://gorenuble.gob.cl/ontology/goreNubleOntology> ;
    skos:prefLabel "Datos Organizacionales GORE Ñuble"@es ;
    skos:definition "Componente de la base de conocimientos (ABox) que contiene las instancias concretas de la estructura orgánica, la división territorial de la Región de Ñuble, el personal institucional, y elementos compartidos (UoM, Aspects)."@es ;
    .

# =============================================================================
# SECCIÓN COMPARTIDA: UNIDADES DE MEDIDA Y ASPECTOS (M3)
# Estas instancias son usadas por múltiples módulos ABox
# =============================================================================

# =============================================================================
# INSTANCIAS DE UNIDADES DE MEDIDA (Extensiones locales de gist)
# =============================================================================

gnubd:_Unit_Percentage
    a gist:UnitOfMeasure ;
    skos:prefLabel "Porcentaje"@es ;
    skos:altLabel "%" ;
    skos:definition "Unidad de medida para razones expresadas como fracción de 100."@es ;
    .

gnubd:_Unit_UTM
    a gist:UnitOfMeasure ;
    skos:prefLabel "Unidad Tributaria Mensual"@es ;
    skos:altLabel "UTM"@es ;
    skos:definition "Unidad económica tributaria utilizada en Chile, ajustada mensualmente por inflación."@es ;
    .

gnubd:_Unit_PesoCLP
    a gist:UnitOfMeasure ;
    skos:prefLabel "Peso Chileno"@es ;
    skos:altLabel "CLP"@es ;
    skos:altLabel "$"@es ;
    skos:definition "Moneda de curso legal de Chile."@es ;
    .

gnubd:_Unit_Month
    a gist:UnitOfMeasure ;
    skos:prefLabel "Mes"@es ;
    skos:definition "Unidad de tiempo equivalente a un doceavo de año."@es ;
    .

# =============================================================================
# INSTANCIAS DE ASPECTOS GIST COMPARTIDOS (para Magnitudes)
# Ubicadas aquí para evitar dependencias cruzadas entre ABox
# =============================================================================

gnubd:_Aspect_AdminCostCap
    a gist:Aspect ;
    skos:prefLabel "Tope Gastos Administración"@es ;
    skos:definition "Aspecto que mide el porcentaje máximo permitido para gastos administrativos."@es ;
    .

